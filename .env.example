# Astana Hotel AI Call Center — mühit dəyişənləri nümunəsi.
# Bu faylı `.env` adı ilə kopyalayın və dəyərləri doldurun. `.env` git-ə düşmür.

# ── STT provayderi ────────────────────────────────────────────────────────
# "local" = faster-whisper (GPU, offline)  |  "groq" = Groq API (GPU tələb etmir)
# Runtime-da admin paneldən də dəyişdirilə bilir (Model parametrləri → stt_provider).
STT_PROVIDER=local

# ── Groq STT (yalnız STT_PROVIDER=groq üçün lazımdır) ─────────────────────
# Açarı https://console.groq.com → API Keys bölməsindən alın (pulsuz).
GROQ_API_KEY=gsk_burani_oz_acarinizla_doldurun
# Modeli/endpoint-i dəyişmək lazım deyil (default-lar işləyir):
# GROQ_STT_MODEL=whisper-large-v3
# GROQ_STT_URL=https://api.groq.com/openai/v1/audio/transcriptions

# ── LLM provayderi ────────────────────────────────────────────────────────
# "local" = Ollama (offline)  |  "gemini" = Google Gemini API (GPU tələb etmir)
# Runtime-da admin paneldən də dəyişilir (Model parametrləri → llm_provider).
LLM_PROVIDER=local

# ── Gemini LLM (yalnız LLM_PROVIDER=gemini üçün lazımdır) ─────────────────
# Açarı https://aistudio.google.com → Get API key bölməsindən alın (pulsuz).
GEMINI_API_KEY=burani_oz_acarinizla_doldurun
# Model (zəif gəlsə gemini-3-flash-a keçin — daha güclü, amma az limit):
# GEMINI_MODEL=gemini-3.1-flash-lite

# ── Digər (opsional) ──────────────────────────────────────────────────────
# WHISPER_MODEL=large-v3-turbo   # kiçik GPU üçün; güclü GPU: large-v3
# WHISPER_DEVICE=cuda
# WHISPER_COMPUTE=int8           # köhnə GPU-larda yeganə işlək rejim; yeni GPU: float16
# LLM_MODEL=gemma4:e4b
# OLLAMA_URL=http://localhost:11434/api/chat
